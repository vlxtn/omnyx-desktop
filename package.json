{
  "name": "omnyx-desktop",
  "version": "0.3.38",
  "description": "Omnyx Desktop AI Companion",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:all": "npm run build && electron-builder --win --mac"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.6.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.omnyx.desktop",
    "productName": "Omnyx Companion",
    "copyright": "Copyright © 2026 Omnyx",
    "directories": {
      "output": "dist",
      "buildResources": "build-assets"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "src/main/tray-icon.png",
        "to": "tray-icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-assets/icon.png",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Omnyx-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Omnyx Companion"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build-assets/icon.png",
      "category": "public.app-category.productivity",
      "artifactName": "Omnyx-${arch}.dmg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build-assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "vlxtn",
      "repo": "omnyx-desktop",
      "releaseType": "release"
    }
  }
}
